        "mode": "runOnceForEachItem",
        "jsCode": "const raw = $input.item.json.text || '';\nlet parsed = {};\ntry {\n  const cleaned = raw.replace(/```json\\s*/gi, '').replace(/```\\s*/g, '').trim();\n  parsed = JSON.parse(cleaned);\n} catch(e) {\n  const match = raw.match(/\\{[\\s\\S]*\\}/);\n  if (match) { try { parsed = JSON.parse(match[0]); } catch(e2) {} }\n}\nconst dateStr = String(parsed['日期'] || parsed.date || '');\nlet dateTs = Date.now();\nif (dateStr) { const d = new Date(dateStr); if (!isNaN(d.getTime())) dateTs = d.getTime(); }\nreturn { json: { '标题': String(parsed['标题'] || '无标题'), '日期_ts': dateTs, '采集时间': Date.now(), '内容': String(parsed['内容'] || ''), '媒体': String(parsed['媒体'] || '未知媒体'), '链接': String(parsed['链接'] || '') } };"
